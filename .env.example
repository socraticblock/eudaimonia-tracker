# Eudaimonia — Environment Variables
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql://philosopher:password@localhost:5432/eudaimonia

# Application
NODE_ENV=development
PORT=3000

# Authentication
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info
